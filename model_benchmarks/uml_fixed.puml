@startuml RAG_chatbot
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle frame
skinparam linetype ortho

skinparam component {
  BackgroundColor #F8F9FA
  BorderColor #495057
  FontSize 11
}
skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #6C757D
  FontColor #343A40
  FontStyle bold
}
skinparam actor {
  BackgroundColor #D0E8FF
  BorderColor #1C6EA4
}
skinparam database {
  BackgroundColor #FFF3CD
  BorderColor #856404
}
skinparam cloud {
  BackgroundColor #D4EDDA
  BorderColor #155724
}
skinparam interface {
  BackgroundColor #E2D9F3
  BorderColor #6610F2
}

' ─── External actors ──────────────────────────────────────────
actor "Frontend\n(React)" as FE
actor "Benchmark\nScripts (Py)" as BM

' ─── External infrastructure ──────────────────────────────────
cloud "Ollama LLM" as OLLAMA
database "PostgreSQL" as PG
database "Milvus\nVector DB" as MILVUS
cloud "MinIO" as MINIO

' ─── Inbound / Primary Adapters ───────────────────────────────
package "Primary Adapters (Inbound)" {
  [AuthController]
  [AnswerModeController]
  [QuestionModeController]
  [ChatController]
  [DocumentController]
}

' ─── Security ─────────────────────────────────────────────────
package "Security (auth)" {
  [WebSecurityConfig]
  [AuthTokenFilter]
  [JwtUtil]
  WebSecurityConfig --> AuthTokenFilter
  AuthTokenFilter --> JwtUtil
}

' ─── Application Core (Hexagon) ───────────────────────────────
package "Application Core (Hexagon)" {

  package "Input Ports" {
    interface ManageUserUseCase
    interface QuestionUseCase
    interface ChatUseCase
  }

  package "Use Cases / Services" {
    [UserService]
    [QuestionModeService]
    [AnswerModeService]
    [ChatMemoryService]
    [RetrievalService]
    [IngestionService]
    [TransformQueryService]
    [UserDetailsService]
    [AuthenticationManagerService]
    [JwtUtilsService]
  }

  package "Output Ports" {
    interface UserRepositoryPort
    interface QuestionRepositoryPort
    interface ChatMemoryPort
    interface DocumentRetrievalPort
  }

  ' Port → Service implementations
  ManageUserUseCase <|.. UserService
  QuestionUseCase   <|.. QuestionModeService
  ChatUseCase       <|.. ChatMemoryService

  ' Internal service dependencies
  UserService          --> UserRepositoryPort
  UserService          --> AuthenticationManagerService
  UserService          --> JwtUtilsService
  UserDetailsService   --> UserRepositoryPort
  JwtUtilsService      --> JwtUtil

  QuestionModeService  --> RetrievalService
  QuestionModeService  --> QuestionRepositoryPort

  AnswerModeService    --> RetrievalService
  AnswerModeService    --> TransformQueryService

  ChatMemoryService    --> ChatMemoryPort
}

' ─── Outbound / Driven Adapters ───────────────────────────────
package "Driven Adapters (Outbound)" {

  package "Persistence Adapters" {
    [UserPersistenceAdapter]
    [QuestionPersistenceAdapter]
    [ChatMemoryPersistenceAdapter]
  }

  package "Persistence Gateways (JPA)" {
    [DataUserRepository]
    [GeneratedQuestionRepository]
    [ChatMemoryRepository]
  }

  package "Chat Memory Adapter" {
    [EncryptedChatMemory]
    [ChatMemoryInspector]
    [ChatHistoryEncryptionService]
    EncryptedChatMemory --> ChatHistoryEncryptionService
    EncryptedChatMemory --> PG
  }

  ' Ports → Adapters
  UserRepositoryPort     <|.. UserPersistenceAdapter
  QuestionRepositoryPort <|.. QuestionPersistenceAdapter
  ChatMemoryPort         <|.. ChatMemoryPersistenceAdapter

  ' Adapters → Gateways
  UserPersistenceAdapter       --> DataUserRepository
  QuestionPersistenceAdapter   --> GeneratedQuestionRepository
  ChatMemoryPersistenceAdapter --> ChatMemoryRepository

  ' Gateways → DB
  DataUserRepository           --> PG
  GeneratedQuestionRepository  --> PG
  ChatMemoryRepository         --> PG
}

' ─── RAG Modules ──────────────────────────────────────────────
package "RAG Modules" {
  [QueryTransformerModule]
  [RewriteQueryModule]
  [TranslationQueryModule]
  [QueryExpansionModule]
  [DocumentSearchModule]
  [DocumentJoinModule]
  [DocumentPostProcessingModule]

  QueryTransformerModule  --> OLLAMA
  RewriteQueryModule      --> OLLAMA
  TranslationQueryModule  --> OLLAMA
  QueryExpansionModule    --> OLLAMA
  DocumentSearchModule    --> MILVUS
}

' ─── Infra / Config ───────────────────────────────────────────
package "Infra Config" {
  [ChatClientConfig]
  [ChatMemoryConfig]
  [MilvusInitializer]
  [IngestionRunner]
  [MinioConfig]
  [EmbeddingConfig]
  [MinIODocumentReader]

  ChatClientConfig  --> OLLAMA
  ChatMemoryConfig  --> EncryptedChatMemory
  IngestionService  --> MinIODocumentReader
  MinIODocumentReader --> MINIO
  IngestionService  --> MILVUS
}

' ─── Actor → Controller flows ─────────────────────────────────
FE --> AuthController
FE --> AnswerModeController
FE --> QuestionModeController
FE --> ChatController
FE --> DocumentController
BM --> AnswerModeController

' ─── Controller → Port/Service flows ──────────────────────────
AuthController         --> ManageUserUseCase
QuestionModeController --> QuestionUseCase
ChatController         --> ChatUseCase
AnswerModeController   --> AnswerModeService
DocumentController     --> RetrievalService

' ─── RetrievalService → RAG Modules ───────────────────────────
RetrievalService --> QueryTransformerModule
RetrievalService --> RewriteQueryModule
RetrievalService --> TranslationQueryModule
RetrievalService --> QueryExpansionModule
RetrievalService --> DocumentSearchModule
RetrievalService --> DocumentJoinModule
RetrievalService --> DocumentPostProcessingModule

' ─── Security filter wiring ───────────────────────────────────
AuthTokenFilter --> UserDetailsService

@enduml
